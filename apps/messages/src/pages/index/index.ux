}

.key-btn-active {
  background-color: #ffffff;
}

.key-text {
  font-size: 28px;
  color: #ffffff;
  font-weight: bold;
}

.text-active-black {
  color: #000000;
}

.space-key {
  width: 110px;
  background-color: #383838;
}

.space-text {
  font-size: 28px;
}

.control-row {
  flex: 1;
  width: 96%;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding-left: 4px;
  padding-right: 4px;
  padding-top: 3px;
  padding-bottom: 3px;
}

.control-btn {
  flex: 1;
  height: 100%;
  background-color: #1a1a1a;
  border-width: 3px;
  border-color: rgba(255, 255, 255, 0.15);
  border-radius: 16px;
  justify-content: center;
  align-items: center;
}

.ctrl-btn-active {
  background-color: #ffffff;
}

.ctrl-center {
  margin-left: 6px;
  margin-right: 6px;
}

