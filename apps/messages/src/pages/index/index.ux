<template>
  <div class="page-container">
    <list class="scroll-view" id="main-list">
      <!-- Combined Main screen containing the 6 rows (fills 100% viewport) -->
      <list-item type="main" class="list-item-main">
        <div class="main-block">
          <!-- Row 1: Dismiss Button -->
          <div class="row-container dismiss-row">
            <input class="btn-dismiss" type="button" value="Dismiss" onclick="handleDismiss" />
          </div>

          <!-- Row 2: Input Display Row -->
          <div class="row-container input-row">
            <div class="input-display-box">
              <text class="input-display-text">{{inputText || 'Type a reply...'}}</text>
            </div>
            <input class="btn-send {{inputText ? 'send-enabled' : ''}}" type="button" value="➤" onclick="handleSend" />
          </div>

          <!-- Rows 3, 4, 5: Keyboard QWERTY rows inside horizontal scroll -->
          <div class="keyboard-scroll-container">
            <scroll class="keyboard-scroll-x" scroll-x="{{true}}">
              <div class="keyboard-keys-container">
                <!-- Row 3: QWERTY Row 1 -->
                <div class="keyboard-row row-padding">
                  <div class="key-btn {{activeKey === item ? 'key-btn-active' : ''}}" for="{{item in row1}}" onclick="handleKeyPress(item)">
                    <text class="key-text {{activeKey === item ? 'text-active-black' : ''}}">{{item}}</text>
                  </div>
                </div>
                <!-- Row 4: QWERTY Row 2 -->
                <div class="keyboard-row row-offset-1 row-padding">
                  <div class="key-btn {{activeKey === item ? 'key-btn-active' : ''}}" for="{{item in row2}}" onclick="handleKeyPress(item)">
                    <text class="key-text {{activeKey === item ? 'text-active-black' : ''}}">{{item}}</text>
                  </div>
                </div>
                <!-- Row 5: QWERTY Row 3 -->
                <div class="keyboard-row row-offset-2 row-padding">
                  <div class="key-btn {{activeKey === item ? 'key-btn-active' : ''}}" for="{{item in row3}}" onclick="handleKeyPress(item)">
                    <text class="key-text {{activeKey === item ? 'text-active-black' : ''}}">{{item}}</text>
                  </div>
                  <!-- Space bar inline in third row -->
                  <div class="key-btn space-key {{activeKey === ' ' ? 'key-btn-active' : ''}}" onclick="handleKeyPress(' ')">
                    <text class="key-text space-text {{activeKey === ' ' ? 'text-active-black' : ''}}">Space</text>
                  </div>
                </div>
              </div>
            </scroll>
          </div>

          <!-- Row 6: Control Row -->
          <div class="row-container control-row">
            <!-- Shift Key / Symbol modifier -->
            <div class="control-btn ctrl-left {{upperFlag && !numFlag ? 'ctrl-active' : ''}} {{activeKey === 'shift' ? 'ctrl-btn-active' : ''}}" onclick="handleToggleShift()">
              <text class="control-text {{upperFlag && !numFlag ? 'text-active' : ''}} {{activeKey === 'shift' ? 'text-active-black' : ''}}">{{numFlag ? '#+=' : '⇧'}}</text>
            </div>

            <!-- Number mode key -->
            <div class="control-btn ctrl-center {{numFlag ? 'ctrl-active' : ''}} {{activeKey === 'num' ? 'ctrl-btn-active' : ''}}" onclick="handleToggleNum()">
              <text class="control-text {{numFlag ? 'text-active' : ''}} {{activeKey === 'num' ? 'text-active-black' : ''}}">{{numFlag ? 'abc' : '123'}}</text>
            </div>

            <!-- Delete key -->
            <div class="control-btn ctrl-right {{activeKey === 'del' ? 'ctrl-btn-active' : ''}}" onclick="handleDeletePress()">
              <text class="control-text {{activeKey === 'del' ? 'text-active-black' : ''}}">⌫</text>
            </div>
          </div>
        </div>
      </list-item>

      <!-- 3. Quick Replies -->
      <list-item type="reply" for="{{replies}}" class="list-item-reply">
        <div class="item-container">
          <input class="btn btn-reply" type="button" value="{{$item}}" onclick="handleReply($item)" />
        </div>
      </list-item>

      <!-- Bottom Spacer -->
      <list-item type="spacer" class="list-item-spacer">
        <div class="spacer"></div>
      </list-item>
    </list>
  </div>
</template>

<script>
import interconnect from '@system.interconnect'
import vibrator from '@system.vibrator'

export default {
  private: {
    connect: null,
    replies: [],
    inputText: '',
    upperFlag: false,
    numFlag: false,
    activeKey: '',
    row1: [],
    row2: [],
    row3: [],
    keys: {
      full: [
        ["Q", "W", "E", "R", "T", "Y", "U", "I", "O", "P"],
        ["A", "S", "D", "F", "G", "H", "J", "K", "L"],
        ["Z", "X", "C", "V", "B", "N", "M"]
      ],
      sign: [
        ["1", "2", "3", "4", "5", "6", "7", "8", "9", "0"],
        ["~", "!", "@", "#", "%", "\"", "\"", "*", "?", "/"],
        ["(", ")", "-", "_", ":", ";", ",", ".", "!"]
      ]
    }
  },

  onInit() {
    this.updateKeyboardRows()
  },

  onRefresh() {
    this.inputText = '' // Clear input on refresh/new notification
    this.upperFlag = false
    this.numFlag = false
    this.activeKey = ''
    this.updateKeyboardRows()
    this.requestReplies()
  },

  onReady() {
    this.handleCreateConn()
  },

  handleCreateConn() {
    const self = this
    try {
      this.connect = interconnect.instance()

      this.connect.onmessage = (data) => {
        try {
          let payload = JSON.parse(data.data)
          if (payload.response) {
            self.replies = payload.response
          }
        } catch (e) {
          console.error('json error: ' + e)
        }
      }

      this.connect.onopen = () => {
        self.requestReplies()
      }

      this.connect.onclose = (data) => {
        console.log('interconnect closed code: ' + (data ? data.code : 'unknown'))
      }

      this.connect.onerror = (data) => {
        console.error('interconnect error code: ' + (data ? data.code : 'unknown'))
      }

      this.connect.getReadyState({
        success: (data) => {
          if (data && (data.status == 1 || data.status === '1')) {
            self.requestReplies()
          }
        }
      })
    } catch (e) {
      console.error('init error: ' + e)
    }
  },

  requestReplies() {
    if (this.connect) {
      try {
        this.connect.send({
          data: { command: 'getReplies' }
        })
      } catch (e) {
        console.error('send error: ' + e)
      }
    }
  },

  updateKeyboardRows() {
    const keysSource = this.numFlag ? this.keys.sign : this.keys.full;
    this.row1 = keysSource[0].map(c => this.numFlag ? c : (this.upperFlag ? c.toUpperCase() : c.toLowerCase()));
    this.row2 = keysSource[1].map(c => this.numFlag ? c : (this.upperFlag ? c.toUpperCase() : c.toLowerCase()));
    this.row3 = keysSource[2].map(c => this.numFlag ? c : (this.upperFlag ? c.toUpperCase() : c.toLowerCase()));
  },

  triggerActiveFeedback(keyId) {
    const self = this;
    this.activeKey = keyId;
    setTimeout(() => {
      if (self.activeKey === keyId) {
        self.activeKey = '';
      }
    }, 250);
  },

  handleKeyPress(char) {
    try {
      vibrator.vibrate({ mode: 'short' })
    } catch(e) {}
    this.inputText += char
    this.triggerActiveFeedback(char)
  },

  handleDeletePress() {
    try {
      vibrator.vibrate({ mode: 'short' })
    } catch(e) {}
    if (this.inputText.length > 0) {
      this.inputText = this.inputText.substring(0, this.inputText.length - 1)
    }
    this.triggerActiveFeedback('del')
  },

  handleToggleShift() {
    try {
      vibrator.vibrate({ mode: 'short' })
    } catch(e) {}
    this.upperFlag = !this.upperFlag
    this.updateKeyboardRows()
    this.triggerActiveFeedback('shift')
  },

  handleToggleNum() {
    try {
      vibrator.vibrate({ mode: 'short' })
    } catch(e) {}
    this.numFlag = !this.numFlag
    this.updateKeyboardRows()
    this.triggerActiveFeedback('num')
  },

  handleSend() {
    if (this.inputText) {
      this.handleReply(this.inputText)
    }
  },

  handleReply(replyText) {
    const self = this;
    if (this.connect) {
      this.connect.send({
        data: { command: 'reply', text: replyText },
        success: () => {
          self.$app.exit()
        },
        fail: () => {
          self.$app.exit()
        }
      })
    } else {
      self.$app.exit()
    }
  },

  handleDismiss() {
    const self = this;
    if (this.connect) {
      this.connect.send({
        data: { command: 'dismiss' },
        success: () => {
          self.$app.exit()
        },
        fail: () => {
          self.$app.exit()
        }
      })
    } else {
      self.$app.exit()
    }
  },

  onDestroy() {
    if (this.connect) {
      this.connect.onmessage = null
      this.connect.onopen = null
      this.connect.onclose = null
      this.connect.onerror = null
    }
  }
}
</script>

