#!/usr/bin/env bash

# Flows
source ./flows/base
source ./flows/git
source ./flows/test

# Vars
GITEA_ORGANIZATION="cellular"
GITEA_REPOSITORY="misync"

build-watch() {
  info "Building all watch apps..."
  mkdir -p assets/rpk
  for app_dir in apps/*; do
    if [ -d "$app_dir" ] && [ -f "$app_dir/package.json" ]; then
      local name
      name=$(basename "$app_dir")
      if [ "$name" = "shared" ]; then
        continue
      fi
      
      info "Syncing shared library to watch app: $name..."
      if [ -d "apps/shared" ]; then
        rm -rf "$app_dir/src/shared"
        mkdir -p "$app_dir/src/shared"
        cp -R apps/shared/ "$app_dir/src/shared/"
      fi
      
      info "Building watch app: $name..."
      (
        cd "$app_dir" || exit 1
        rm -rf dist build
        if [ ! -d "node_modules" ]; then
          npm install || exit 1
        fi
        npm run build || exit 1
        
        local pkg="com.misync.$name"
        
        local rpk
        rpk=$(find dist -maxdepth 1 -name "*.rpk" | head -n 1)
        if [ -n "$rpk" ]; then
          cp "$rpk" "../../assets/rpk/$pkg.rpk" || exit 1
          success "Copied RPK: $pkg.rpk"
        else
          error "No RPK file found in dist/ for $name"
          exit 1
        fi
      ) || abort "Failed to build $name watch app." 2
    fi
  done
}

build-proto() {
  info "Compiling Protocol Buffer schemas..."
  export PATH="$PATH:$HOME/.pub-cache/bin"
  protoc --dart_out=lib/device/proto -Iproto proto/xiaomi.proto || abort "Failed to compile protobuf schemas." 2
}

build-icon() {
  info "Converting icon SVG to PNG..."
  if command -v rsvg-convert &> /dev/null; then
    rsvg-convert -w 1024 -h 1024 assets/icon/icon.svg -o assets/icon/icon.png || abort "Failed to convert icon SVG to PNG." 2
  else
    warning "rsvg-convert is not installed. Skipping SVG to PNG conversion."
  fi
  info "Generating launcher icons..."
  dart run flutter_launcher_icons || abort "Failed to generate launcher icons." 2
}

build-fonts() {
  local font_dir="assets/font"
  local font_file="$font_dir/material.ttf"
  local font_url="https://raw.githubusercontent.com/google/material-design-icons/master/variablefont/MaterialSymbolsOutlined%5BFILL%2CGRAD%2Copsz%2Cwght%5D.ttf"
  local codepoints_file="$font_dir/material.txt"
  local codepoints_url="https://raw.githubusercontent.com/google/material-design-icons/master/variablefont/MaterialSymbolsOutlined%5BFILL%2CGRAD%2Copsz%2Cwght%5D.codepoints"

  mkdir -p "$font_dir"

  # Clean up old filename if it exists
  if [ -f "$font_dir/MaterialSymbolsOutlined.ttf" ]; then
    rm "$font_dir/MaterialSymbolsOutlined.ttf"
  fi

  info "Checking for Material Symbols Variable Font updates..."
  local curl_opts=("-L" "-o" "$font_file")
  if [ -f "$font_file" ]; then
    curl_opts+=("-z" "$font_file")
  fi
  curl "${curl_opts[@]}" "$font_url" || warning "Failed to check or download symbols font."

  info "Checking for Material Symbols codepoints updates..."
  local curl_opts_txt=("-L" "-o" "$codepoints_file")
  if [ -f "$codepoints_file" ]; then
    curl_opts_txt+=("-z" "$codepoints_file")
  fi
  curl "${curl_opts_txt[@]}" "$codepoints_url" || warning "Failed to check or download codepoints list."
  
  if [ -f "$font_file" ] && [ -f "$codepoints_file" ]; then
    success "Material Symbols font and dictionary are ready."
  else
    error "Font files are missing!"
    return 1
  fi
}

build-apk() {
  local sources_dir=".apks"
  local apk_path="$sources_dir/com.xiaomi.wear.apk"
  local decompiled_dir="$sources_dir/mi_fitness_source"
  local version_file="$sources_dir/version.txt"
  
  mkdir -p "$sources_dir"

  info "Checking for latest Chinese Mi Fitness APK..."
  local latest_version
  latest_version=$(curl --connect-timeout 3 --max-time 5 -s -D - "https://hlth.io.mi.com/download?appId=mifitness" -o /dev/null | grep -i "location:" | awk -F'/' '{print $5}' | awk -F'?' '{print $1}')
  
  if [ -z "$latest_version" ]; then
    warning "Could not fetch latest version name. Skipping download checks."
  else
    local current_version=""
    [ -f "$version_file" ] && current_version=$(cat "$version_file")

    if [ "$latest_version" != "$current_version" ] || [ ! -d "$decompiled_dir" ] || [ ! -f "$apk_path" ]; then
      info "New version detected: $latest_version. Downloading APK..."
      curl --connect-timeout 5 -L -o "$apk_path" "https://hlth.io.mi.com/download?appId=mifitness" || abort "Failed to download latest APK." 2
      
      # Clean up old decompiled directory if it exists
      if [ -d "$decompiled_dir" ]; then
        info "Cleaning up old decompiled folder..."
        rm -rf "$decompiled_dir"
      fi

      info "Decompiling source files using jadx..."
      # jadx can exit with non-zero codes on minor obfuscated class errors.
      # We verify that the sources output directory was created successfully instead.
      jadx -d "$decompiled_dir" "$apk_path"
      if [ ! -d "$decompiled_dir/sources" ]; then
        abort "Failed to decompile APK (sources directory not created)." 2
      fi
      
      echo "$latest_version" > "$version_file"
      success "Decompiled $latest_version successfully."
    else
      info "Local decompiled sources are up to date ($current_version)."
    fi
  fi
}

build-generate() {
  info "Generating sport schemas..."
  dart lib/health/generators/schemas.dart || abort "Failed to generate sport schemas." 2
}

build() {
  build-apk || exit $?
  build-generate || exit $?
  build-watch || exit $?
  build-proto || exit $?
  build-icon || exit $?
  build-fonts || exit $?
  success "Build completed successfully."
}

clean() {
  info "Cleaning watch app build directories..."
  rm -rf apps/messages/build apps/messages/dist
  info "Cleaning Flutter build artifacts..."
  flutter clean
  success "Clean completed successfully."
}

analyze() {
  info "Running static analysis..."
  flutter analyze || abort "Static analysis failed." 2
  success "Static analysis completed successfully."
}

get-device() {
  local device
  device=$(adb devices | grep -v "List" | grep "device" | awk '{print $1}' | head -n 1)
  if [ -z "$device" ]; then
    error "No connected Android devices found via adb."
    return 1
  fi
  echo "$device"
}

debug() {
  local dev
  dev=$(get-device) || exit $?
  info "Running on device $dev in debug mode..."
  flutter run -d "$dev"
}

release() {
  local dev
  dev=$(get-device) || exit $?
  info "Running on device $dev in release mode..."
  flutter run -d "$dev" --release
}

doc() {
  info "Documenting Mi Fitness Vela Quick App Guide..."
  siteone-crawler \
    --url="https://iot.mi.com/vela/quickapp/en/guide/" \
    --max-depth=0 \
    --include-regex="\/vela\/quickapp\/en\/" \
    --ignore-robots-txt \
    --browser \
    --offline-export-preserve-url-structure \
    --markdown-export-dir="./docs/xiaomi_vela_quickapp" \
    --markdown-move-content-before-h1-to-end
}

misync-usage() {
  echo "build|Build watch applications, APK schemas, and protobuf schemas."
  echo "build-apk|Manage Chinese Mi Fitness APK version and extraction."
  echo "build-generate|Regenerate sport schemas from extracted APK sources."
  echo "build-watch|Build watch apps (Messages) and copy RPK to assets."
  echo "build-proto|Compile Protocol Buffer schemas."
  echo "build-icon|Generate launcher icons."
  echo "build-fonts|Download or update Material Symbols font."
  echo "clean|Clean watch app and Flutter build artifacts."
  echo "analyze|Run static analysis checks."
  echo "debug|Run Flutter app in debug mode on connected device."
  echo "release|Run Flutter app in release mode on connected device."
}

misync-flow() {
  case "$1" in
    build) build; return $?;;
    build-apk) build-apk; return $?;;
    build-generate) build-generate; return $?;;
    build-watch) build-watch; return $?;;
    build-proto) build-proto; return $?;;
    build-icon) build-icon; return $?;;
    build-fonts) build-fonts; return $?;;
    clean) clean; return $?;;
    analyze) analyze; return $?;;
    debug) build && debug; return $?;;
    release) release; return $?;;
    *) return 127 ;;
  esac
}

register-flow "misync"

dispatch "$@"