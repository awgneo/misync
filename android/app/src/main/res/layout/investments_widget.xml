<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1219"
    android:padding="8dp">

    <!-- Header Area -->
    <RelativeLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_alignParentTop="true"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:layout_marginLeft="8dp"
            android:text="MiSync Investments"
            android:textColor="#00E5FF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btn_refresh"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginRight="8dp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:contentDescription="Refresh Data"
            android:padding="6dp"
            android:src="@android:drawable/ic_popup_sync"
            android:tint="#00E5FF" />
    </RelativeLayout>

    <!-- Divider Line -->
    <FrameLayout
        android:id="@+id/widget_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/widget_header"
        android:background="#26324D" />

    <!-- Watchlist ViewPager -->
    <AdapterViewFlipper
        android:id="@+id/watchlists_viewpager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/widget_divider"
        android:layout_marginTop="4dp" />

    <!-- Empty/Fallback View -->
    <TextView
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/widget_divider"
        android:gravity="center"
        android:text="No watchlist data. Please enable sync &amp; enter credentials."
        android:textColor="#888888"
        android:textSize="12sp"
        android:visibility="gone" />

</RelativeLayout>
